# ─── Browser Worker Config ───────────────────────────────────────────────────

# Port the worker API listens on
WORKER_PORT=3001

# Absolute path to your real Google Chrome executable
# Windows example:
CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS example:
# CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux example:
# CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome

# Absolute path to the dedicated agent Chrome profile directory
# This MUST be different from your everyday Chrome profile
CHROME_PROFILE_DIR=C:\Users\YourUser\Documents\anyclick\browser-worker\profiles\chrome-agent-profile

# ─── Gemini API ──────────────────────────────────────────────────────────────

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# ─── Debug ───────────────────────────────────────────────────────────────────

# Set to true to show numbered element overlays on screen
DEBUG_OVERLAY=false

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
